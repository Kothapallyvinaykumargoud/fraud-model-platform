{
  "title": "Fraud Model Platform",
  "uid": "fraud-platform",
  "schemaVersion": 39,
  "version": 3,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    { "id": 100, "title": "Business / client view", "type": "row", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 } },
    {
      "id": 101,
      "title": "Transaction value processed",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "currencyUSD" } },
      "targets": [
        {
          "expr": "sum by (verdict) (rate(transaction_amount_sum[5m]))",
          "legendFormat": "{{verdict}}"
        }
      ]
    },
    {
      "id": 102,
      "title": "Fraud rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0 } },
      "targets": [
        {
          "expr": "sum(rate(predictions_total{verdict=\"fraud\"}[5m])) / sum(rate(predictions_total[5m]))",
          "legendFormat": "fraud rate"
        }
      ]
    },
    {
      "id": 103,
      "title": "$ flagged as fraud (cumulative)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "currencyUSD" } },
      "targets": [{ "expr": "fraud_value_flagged_total" }]
    },
    {
      "id": 106,
      "title": "Fraud by card network",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum by (card4) (rate(transactions_by_card_type_total{verdict=\"fraud\"}[15m]))",
          "legendFormat": "{{card4}}"
        }
      ]
    },
    {
      "id": 107,
      "title": "Fraud by device type",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum by (device_type) (rate(transactions_by_device_total{verdict=\"fraud\"}[15m]))",
          "legendFormat": "{{device_type}}"
        }
      ]
    },

    { "id": 200, "title": "Data science / model view", "type": "row", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 } },
    {
      "id": 201,
      "title": "Drift score vs threshold — FR-12",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "drift_score", "legendFormat": "drift_score" },
        { "expr": "drift_threshold", "legendFormat": "threshold" }
      ]
    },
    {
      "id": 202,
      "title": "Shadow vs production agreement rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(rate(shadow_predictions_total{agreement=\"match\"}[15m])) / sum(rate(shadow_predictions_total[15m]))"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 } }
    },
    {
      "id": 203,
      "title": "Shadow model loaded",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [{ "expr": "shadow_model_loaded" }],
      "fieldConfig": { "defaults": { "mappings": [
        { "type": "value", "options": { "0": { "text": "No shadow" }, "1": { "text": "Shadow active" } } }
      ] } }
    },
    {
      "id": 204,
      "title": "Shadow predictions by verdict + agreement",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum by (verdict, agreement) (rate(shadow_predictions_total[5m]))",
          "legendFormat": "{{verdict}} ({{agreement}})"
        }
      ]
    },
    {
      "id": 205,
      "title": "Transaction amount distribution by verdict",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 26 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, verdict) (rate(transaction_amount_bucket[5m])))",
          "legendFormat": "p95 amount ({{verdict}})"
        }
      ]
    },
    {
      "id": 206,
      "title": "Confirmed precision / recall (lagged ground truth)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 34 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "description": "Only reflects predictions whose true label has been confirmed by mlops/label_feedback.py — a real bank only learns this after a chargeback lands, so this necessarily lags real-time verdicts.",
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 } },
      "targets": [
        { "expr": "confirmed_precision", "legendFormat": "confirmed precision" },
        { "expr": "confirmed_recall", "legendFormat": "confirmed recall" }
      ]
    },
    {
      "id": 207,
      "title": "Avg. label confirmation lag",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 34 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [{ "expr": "label_feedback_lag_seconds" }]
    },
    {
      "id": 208,
      "title": "Predictions awaiting label confirmation",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 34 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [{ "expr": "label_feedback_pending" }]
    },

    { "id": 300, "title": "Engineering / ops view", "type": "row", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 42 } },
    {
      "id": 301,
      "title": "Prediction latency (p95) — FR-11",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 43 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(inference_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95 latency"
        }
      ]
    },
    {
      "id": 302,
      "title": "Predictions by verdict — FR-11",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 43 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum by (verdict) (rate(predictions_total[5m]))",
          "legendFormat": "{{verdict}}"
        }
      ]
    },
    {
      "id": 303,
      "title": "Pod memory usage (working set) — FR-10",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 51 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum by (pod) (container_memory_working_set_bytes{namespace=\"fraud-platform\", container!=\"\"})",
          "legendFormat": "{{pod}}"
        }
      ]
    },
    {
      "id": 304,
      "title": "Pod CPU usage — FR-10",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 51 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum by (pod) (rate(container_cpu_usage_seconds_total{namespace=\"fraud-platform\", container!=\"\"}[5m]))",
          "legendFormat": "{{pod}}"
        }
      ]
    }
  ]
}
