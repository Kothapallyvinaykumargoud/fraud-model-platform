# The registered model (production_pointer.json, models/production/,
# models/packages/ rollback history, registration/validation logs) IS
# committed — CI builds the Docker image from it. What's excluded here is
# raw/near-raw slices of the Kaggle dataset, which the dataset's terms
# don't clear for redistribution in a public repo — only the trained model
# artifact ships, not the data it was trained on.
data/*.csv
models/candidate/
models/candidate2/
models/candidate_retrain/
models/drift_state.json
